<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:ext="http://www.liquibase.org/xml/ns/dbchangelog-ext"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd
                        http://www.liquibase.org/xml/ns/dbchangelog-ext http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-ext.xsd">

    <!--
        Added the entity AppelOffre.
    -->
    <changeSet id="20260312184300-1" author="jhipster">
        <createTable tableName="appel_offre">
            <column name="id" type="bigint">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="reference" type="varchar(255)">
                <constraints nullable="false" unique="true" uniqueConstraintName="ux_appel_offre__reference" />
            </column>
            <column name="titre" type="varchar(255)">
                <constraints nullable="false" />
            </column>
            <column name="description" type="${blobType}">
                <constraints nullable="true" />
            </column>
            <column name="description_content_type" type="varchar(255)">
                <constraints nullable="true" />
            </column>
            <column name="date_cloture" type="${datetimeType}">
                <constraints nullable="true" />
            </column>
            <column name="statut" type="varchar(255)">
                <constraints nullable="true" />
            </column>
            <!-- jhipster-needle-liquibase-add-column - JHipster will add columns here -->
        </createTable>
        <dropDefaultValue tableName="appel_offre" columnName="date_cloture" columnDataType="${datetimeType}"/>
    </changeSet>

